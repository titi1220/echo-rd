# Public production URL, for example https://echord.org or your Vercel domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CAPTCHA provider keys. Optional for local demo, recommended for production forms.
NEXT_PUBLIC_CAPTCHA_SITE_KEY=your-captcha-site-key
CAPTCHA_SECRET_KEY=your-captcha-secret-key
